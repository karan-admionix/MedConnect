<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="doctor_specialization_view_list" model="ir.ui.view">
        <field name="name">doctor.specialization.list</field>
        <field name="model">doctor.specialization</field>
        <field name="arch" type="xml">
            <list string="Specializations">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <field name="doctor_count"/>
                <field name="featured"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="doctor_specialization_view_form" model="ir.ui.view">
        <field name="name">doctor.specialization.form</field>
        <field name="model">doctor.specialization</field>
        <field name="arch" type="xml">
            <form string="Specialization">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Cardiology"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="icon"/>
                            <field name="featured"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Sub-specializations" name="children">
                            <field name="child_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="doctor_specialization_action" model="ir.actions.act_window">
        <field name="name">Specializations</field>
        <field name="res_model">doctor.specialization</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first specialization</p>
        </field>
    </record>

</odoo>
