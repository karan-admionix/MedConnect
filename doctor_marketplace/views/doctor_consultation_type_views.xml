<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="doctor_consultation_type_view_list" model="ir.ui.view">
        <field name="name">doctor.consultation.type.list</field>
        <field name="model">doctor.consultation.type</field>
        <field name="arch" type="xml">
            <list string="Consultation Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="doctor_consultation_type_view_form" model="ir.ui.view">
        <field name="name">doctor.consultation.type.form</field>
        <field name="model">doctor.consultation.type</field>
        <field name="arch" type="xml">
            <form string="Consultation Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="icon"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="doctor_consultation_type_action" model="ir.actions.act_window">
        <field name="name">Consultation Types</field>
        <field name="res_model">doctor.consultation.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
