<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View — editable only by managers -->
    <record id="doctor_schedule_view_list" model="ir.ui.view">
        <field name="name">doctor.schedule.list</field>
        <field name="model">doctor.schedule</field>
        <field name="arch" type="xml">
            <list string="Schedule" editable="bottom"
                  create="0" delete="0">
                <field name="doctor_id"/>
                <field name="day_of_week"/>
                <field name="time_from" widget="float_time"/>
                <field name="time_to" widget="float_time"/>
                <field name="slot_count"/>
                <field name="is_available"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="doctor_schedule_view_form" model="ir.ui.view">
        <field name="name">doctor.schedule.form</field>
        <field name="model">doctor.schedule</field>
        <field name="arch" type="xml">
            <form string="Schedule">
                <group>
                    <group>
                        <field name="doctor_id"/>
                        <field name="day_of_week"/>
                    </group>
                    <group>
                        <field name="time_from" widget="float_time"/>
                        <field name="time_to" widget="float_time"/>
                        <field name="is_available"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Action — accessible to Manager/Admin only (enforced via menu groups) -->
    <record id="doctor_schedule_action" model="ir.actions.act_window">
        <field name="name">Doctor Schedules</field>
        <field name="res_model">doctor.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
