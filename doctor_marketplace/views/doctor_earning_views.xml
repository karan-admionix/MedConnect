<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="doctor_earning_view_list" model="ir.ui.view">
        <field name="name">doctor.earning.list</field>
        <field name="model">doctor.earning</field>
        <field name="arch" type="xml">
            <list string="Earnings">
                <field name="date"/>
                <field name="doctor_id"/>
                <field name="appointment_id"/>
                <field name="earning_type"/>
                <field name="gross_amount" sum="Total Gross"/>
                <field name="platform_commission" sum="Total Commission"/>
                <field name="net_amount" sum="Total Net"/>
                <field name="is_paid"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="doctor_earning_view_form" model="ir.ui.view">
        <field name="name">doctor.earning.form</field>
        <field name="model">doctor.earning</field>
        <field name="arch" type="xml">
            <form string="Earning">
                <sheet>
                    <group>
                        <group>
                            <field name="doctor_id"/>
                            <field name="appointment_id"/>
                            <field name="date"/>
                            <field name="earning_type"/>
                        </group>
                        <group>
                            <field name="gross_amount"/>
                            <field name="platform_commission"/>
                            <field name="net_amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="payout_id"/>
                        <field name="is_paid"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="doctor_earning_action" model="ir.actions.act_window">
        <field name="name">Earnings</field>
        <field name="res_model">doctor.earning</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
