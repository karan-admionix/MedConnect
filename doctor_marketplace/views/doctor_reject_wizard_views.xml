<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="doctor_reject_wizard_view_form" model="ir.ui.view">
        <field name="name">doctor.reject.wizard.form</field>
        <field name="model">doctor.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Doctor Registration">
                <group>
                    <field name="doctor_id" readonly="1"/>
                    <field name="rejection_reason"
                           placeholder="Enter the reason for rejection (mandatory)…"
                           required="1"
                           rows="5"/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            string="Confirm Rejection"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="doctor_reject_wizard_action" model="ir.actions.act_window">
        <field name="name">Reject Doctor Registration</field>
        <field name="res_model">doctor.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="doctor_reject_wizard_view_form"/>
        <field name="target">new</field>
    </record>

</odoo>
