<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="doctor_payout_view_list" model="ir.ui.view">
        <field name="name">doctor.payout.list</field>
        <field name="model">doctor.payout</field>
        <field name="arch" type="xml">
            <list string="Payouts">
                <field name="name"/>
                <field name="create_date"/>
                <field name="doctor_id"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
                <field name="payment_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="doctor_payout_view_form" model="ir.ui.view">
        <field name="name">doctor.payout.form</field>
        <field name="model">doctor.payout</field>
        <field name="arch" type="xml">
            <form string="Payout">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_process" string="Process" type="object" invisible="state != 'pending'"
                            groups="doctor_marketplace.group_doctor_marketplace_manager"/>
                    <button name="action_complete" string="Complete" type="object" class="btn-success"
                            invisible="state != 'processing'"
                            groups="doctor_marketplace.group_doctor_marketplace_manager"/>
                    <button name="action_fail" string="Mark Failed" type="object" class="btn-danger"
                            invisible="state != 'processing'"
                            groups="doctor_marketplace.group_doctor_marketplace_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state not in ('draft', 'pending')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,processing,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="doctor_id"/>
                            <field name="amount"/>
                            <field name="earning_count"/>
                        </group>
                        <group>
                            <field name="payment_method"/>
                            <field name="payment_reference"/>
                            <field name="payment_date"/>
                        </group>
                    </group>
                    <group string="Bank Details">
                        <group>
                            <field name="bank_name"/>
                            <field name="bank_account"/>
                            <field name="bank_ifsc"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Earnings" name="earnings">
                            <field name="earning_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="appointment_id"/>
                                    <field name="earning_type"/>
                                    <field name="net_amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="doctor_payout_action" model="ir.actions.act_window">
        <field name="name">Payouts</field>
        <field name="res_model">doctor.payout</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Pending Payouts Action -->
    <record id="doctor_payout_action_pending" model="ir.actions.act_window">
        <field name="name">Pending Payouts</field>
        <field name="res_model">doctor.payout</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['pending', 'processing'])]</field>
    </record>

</odoo>
