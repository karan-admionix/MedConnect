<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="doctor_badge_view_list" model="ir.ui.view">
        <field name="name">doctor.badge.list</field>
        <field name="model">doctor.badge</field>
        <field name="arch" type="xml">
            <list string="Doctor Badges">
                <field name="name"/>
                <field name="code"/>
                <field name="level"/>
                <field name="auto_assign"/>
                <field name="min_rating"/>
                <field name="min_consultations"/>
                <field name="doctor_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="doctor_badge_view_form" model="ir.ui.view">
        <field name="name">doctor.badge.form</field>
        <field name="model">doctor.badge</field>
        <field name="arch" type="xml">
            <form string="Doctor Badge">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Badge Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="level"/>
                            <field name="icon"/>
                            <field name="color"/>
                        </group>
                        <group>
                            <field name="auto_assign"/>
                            <field name="requires_audit"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Criteria" invisible="not auto_assign">
                        <group>
                            <field name="min_rating"/>
                            <field name="min_reviews"/>
                            <field name="min_consultations"/>
                        </group>
                        <group>
                            <field name="min_months_active"/>
                            <field name="max_complaint_rate"/>
                        </group>
                    </group>
                    <group string="Benefits">
                        <group>
                            <field name="search_priority"/>
                            <field name="premium_percentage"/>
                            <field name="featured_eligible"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Doctors with Badge" name="doctors">
                            <field name="doctor_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="doctor_badge_action" model="ir.actions.act_window">
        <field name="name">Doctor Badges</field>
        <field name="res_model">doctor.badge</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
