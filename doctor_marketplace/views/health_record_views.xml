<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="patient_health_record_view_list" model="ir.ui.view">
        <field name="name">patient.health.record.list</field>
        <field name="model">patient.health.record</field>
        <field name="arch" type="xml">
            <list string="Health Records">
                <field name="record_date"/>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="record_type"/>
                <field name="doctor_id"/>
                <field name="source"/>
                <field name="is_verified"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="patient_health_record_view_form" model="ir.ui.view">
        <field name="name">patient.health.record.form</field>
        <field name="model">patient.health.record</field>
        <field name="arch" type="xml">
            <form string="Health Record">
                <header>
                    <button name="action_verify" string="Verify" type="object" class="btn-success"
                            invisible="is_verified" groups="doctor_marketplace.group_doctor_marketplace_manager"/>
                    <button name="action_generate_share_link" string="Generate Share Link" type="object"
                            invisible="is_shared"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="patient_id"/>
                            <field name="record_type"/>
                            <field name="record_date"/>
                        </group>
                        <group>
                            <field name="doctor_id"/>
                            <field name="appointment_id"/>
                            <field name="source"/>
                            <field name="is_verified"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details" name="details">
                            <group>
                                <field name="description"/>
                            </group>
                            <field name="notes"/>
                        </page>
                        <page string="Attachment" name="attachment">
                            <group>
                                <field name="attachment" filename="attachment_filename"/>
                                <field name="attachment_filename" invisible="1"/>
                            </group>
                        </page>
                        <page string="Sharing" name="sharing">
                            <group>
                                <group>
                                    <field name="is_shared"/>
                                    <field name="share_token" invisible="not is_shared"/>
                                    <field name="share_expiry" invisible="not is_shared"/>
                                </group>
                            </group>
                            <field name="shared_with_doctor_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Verification" name="verification" invisible="not is_verified">
                            <group>
                                <field name="verified_by"/>
                                <field name="verified_date"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="patient_health_record_action" model="ir.actions.act_window">
        <field name="name">Health Records</field>
        <field name="res_model">patient.health.record</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
