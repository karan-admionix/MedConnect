<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- FAQ FORUM                                                    -->
        <!-- Separate forum in discussions mode, high karma to post,     -->
        <!-- low karma to read and comment — admin-curated FAQs          -->
        <!-- ============================================================ -->
        <record id="forum_faq" model="forum.forum">
            <field name="name">MedConnect Help Center</field>
            <field name="website_id" ref="website.default_website"/>
            <field name="privacy">public</field>
            <field name="mode">discussions</field>
            <field name="description">
                Frequently asked questions and help articles for patients,
                doctors, and platform users.
            </field>

            <!-- Only admins/staff can post FAQs -->
            <field name="karma_ask">5000</field>
            <field name="karma_answer">1</field>
            <field name="karma_edit_own">1</field>
            <field name="karma_edit_all">300</field>
            <field name="karma_edit_retag">75</field>
            <field name="karma_close_own">100</field>
            <field name="karma_close_all">500</field>
            <field name="karma_unlink_own">500</field>
            <field name="karma_unlink_all">1000</field>
            <field name="karma_tag_create">150</field>
            <field name="karma_upvote">1</field>
            <field name="karma_downvote">50</field>
            <field name="karma_answer_accept_own">20</field>
            <field name="karma_answer_accept_all">500</field>
            <field name="karma_comment_own">1</field>
            <field name="karma_comment_all">1</field>
            <field name="karma_comment_convert_own">50</field>
            <field name="karma_comment_convert_all">500</field>
            <field name="karma_comment_unlink_own">50</field>
            <field name="karma_comment_unlink_all">500</field>
            <field name="karma_flag">500</field>
            <field name="karma_dofollow">500</field>
            <field name="karma_editor">30</field>
            <field name="karma_user_bio">750</field>
            <field name="karma_post">5000</field>
            <field name="karma_moderate">1000</field>

            <!-- Karma Gains -->
            <field name="karma_gen_question_new">0</field>
            <field name="karma_gen_question_upvote">5</field>
            <field name="karma_gen_question_downvote">0</field>
            <field name="karma_gen_answer_upvote">5</field>
            <field name="karma_gen_answer_downvote">0</field>
            <field name="karma_gen_answer_accept">2</field>
            <field name="karma_gen_answer_accepted">15</field>
            <field name="karma_gen_answer_flagged">0</field>
        </record>

        <!-- FAQ Tags -->
        <record id="faq_tag_account" model="forum.tag">
            <field name="name">Account &amp; Login</field>
            <field name="forum_id" ref="forum_faq"/>
            <field name="color">4</field>
        </record>

        <record id="faq_tag_appointments" model="forum.tag">
            <field name="name">Appointments</field>
            <field name="forum_id" ref="forum_faq"/>
            <field name="color">4</field>
        </record>

        <record id="faq_tag_payments" model="forum.tag">
            <field name="name">Payments &amp; Billing</field>
            <field name="forum_id" ref="forum_faq"/>
            <field name="color">4</field>
        </record>

        <record id="faq_tag_doctors" model="forum.tag">
            <field name="name">For Doctors</field>
            <field name="forum_id" ref="forum_faq"/>
            <field name="color">5</field>
        </record>

        <record id="faq_tag_patients" model="forum.tag">
            <field name="name">For Patients</field>
            <field name="forum_id" ref="forum_faq"/>
            <field name="color">5</field>
        </record>

        <record id="faq_tag_technical" model="forum.tag">
            <field name="name">Technical Support</field>
            <field name="forum_id" ref="forum_faq"/>
            <field name="color">1</field>
        </record>

    </data>
</odoo>