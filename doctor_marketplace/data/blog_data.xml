<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- BLOGS (Medical Categories)                                   -->
        <!-- ============================================================ -->
        <record id="blog_patient_education" model="blog.blog">
            <field name="name">Patient Education</field>
            <field name="subtitle">Evidence-based health information for patients and families</field>
        </record>

        <record id="blog_doctor_insights" model="blog.blog">
            <field name="name">Doctor Insights</field>
            <field name="subtitle">Clinical knowledge and professional perspectives from our doctors</field>
        </record>

        <record id="blog_treatment_guides" model="blog.blog">
            <field name="name">Treatment Guides</field>
            <field name="subtitle">Step-by-step guides for common treatments and procedures</field>
        </record>

        <record id="blog_health_news" model="blog.blog">
            <field name="name">Health News</field>
            <field name="subtitle">Latest developments in medicine and healthcare</field>
        </record>

        <record id="blog_wellness" model="blog.blog">
            <field name="name">Wellness &amp; Prevention</field>
            <field name="subtitle">Tips and advice for a healthier lifestyle</field>
        </record>

        <!-- ============================================================ -->
        <!-- TAG CATEGORIES                                               -->
        <!-- ============================================================ -->
        <record id="blog_tag_cat_specialty" model="blog.tag.category">
            <field name="name">Medical Specialty</field>
