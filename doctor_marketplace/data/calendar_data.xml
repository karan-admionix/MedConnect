<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- APPOINTMENT TYPE — Doctor Consultation                       -->
        <!-- Uses Odoo's native appointment module already installed      -->
        <!-- ============================================================ -->
        <record id="appointment_type_consultation" model="appointment.type">
            <field name="name">Doctor Consultation</field>
            <field name="category">custom</field>
            <field name="min_cancellation_hours">2</field>
            <field name="min_schedule_hours">1</field>
            <field name="max_schedule_days">30</field>
            <field name="appointment_duration">0.5</field>
        </record>

        <record id="appointment_type_followup" model="appointment.type">
            <field name="name">Follow-up Consultation</field>
            <field name="category">custom</field>
            <field name="min_cancellation_hours">1</field>
            <field name="min_schedule_hours">1</field>
            <field name="max_schedule_days">30</field>
            <field name="appointment_duration">0.25</field>
        </record>

    </data>
</odoo>