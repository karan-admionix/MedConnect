<odoo>
    <data noupdate="1">

        <!-- Find Doctors -->
        <record id="menu_find_doctors" model="website.menu">
            <field name="name">Find Doctors</field>
            <field name="url">/doctors</field>
            <field name="sequence">20</field>
            <field name="parent_id" ref="website.main_menu"/>
        </record>

        <!-- Doctor Registration -->
        <record id="menu_doctor_registration" model="website.menu">
            <field name="name">Doctor Registration</field>
            <field name="url">/doctor-registration</field>
            <field name="sequence">40</field>
            <field name="parent_id" ref="website.main_menu"/>
        </record>

    </data>

    <!-- Delete the Appointment menu if it exists -->
    <data noupdate="0">
        <delete model="website.menu" search="[('url', '=', '/appointment')]"/>
    </data>
</odoo>